# --- Font ---
font-family = "Iosevka Nerd Font Mono"
font-size = 15
font-thicken = true

# --- The Aesthetic ---
# Choose your favorite here:
#theme = Vesper
#theme = Later This Evening

# If you want a TRUE pitch-black background (even if the theme uses dark gray),
# uncomment the line below:
# background = #000000

# --- Match Neovim Darkvoid Setup ---
background = #1c1c1c
foreground = #c0c0c0
cursor-color = #bdfe58
selection-background = #303030

# High Contrast Palette from your Lua Setup
palette = 0=#1c1c1c
palette = 1=#dea6a0
palette = 2=#bdfe58
palette = 3=#d6efd8
palette = 4=#7fa1c3
palette = 5=#bedc74
palette = 6=#1bfd9c
palette = 7=#c0c0c0
palette = 8=#585858
palette = 9=#ffb3ba
palette = 10=#baffc9
palette = 11=#ffffba
palette = 12=#afd7ff
palette = 13=#ffafd7
palette = 14=#afffff
palette = 15=#ffffff

# --- Blur/Transparency (Optional) ---
# If you want it to feel even more premium on Mac:
# window-background-opacity = 1.0
# window-blur-radius = 20




# --- Fix the Gap & Titlebar ---
macos-titlebar-style = hidden
window-decoration = false

# Padding - 5 looks good for breathing room
window-padding-x = 0
window-padding-y = 0

# --- Window Size ---
window-width = 180
window-height = 50

# --- Advanced Mac Display (Optional) ---
# Since you're on a 2021 ARM Mac, this makes the darks deeper
window-colorspace = display-p3
